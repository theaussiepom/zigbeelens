# Optional selector used by docker-compose.example.yaml.
#
# `latest` is the newest tagged release. Replace it with `edge` or `main` only
# for deliberate current-main/pre-release validation, or use a `sha-*` tag for
# traceability. A pinned X.Y.Z tag is the most reproducible released install.
ZIGBEELENS_IMAGE=ghcr.io/theaussiepom/zigbeelens:latest

# Supported service-environment examples:
#   ZIGBEELENS_LOG_LEVEL=info  # debug | info | warning | error
#   TZ=UTC                     # process/log timezone; UI uses browser timezone
