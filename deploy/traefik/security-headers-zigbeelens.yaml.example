# Traefik dynamic middleware — TLS/proxy transport for ZigbeeLens Core.
#
# Copy to your Traefik file provider directory, e.g.:
#   /mnt/nas/docker/network/traefik/conf.d/middlewares/security-headers-zigbeelens.yaml
#
# Reference from ZigbeeLens router labels:
#   traefik.http.routers.zigbeelens.middlewares: local@file,authentik@file,securityHeadersZigbeeLens@file
#
# Core owns CORS, CSP, frame ancestors, nosniff, and referrer policy.
# Do not configure Traefik to broaden those with wildcards or a looser CSP.
#
# Configure exact Home Assistant framing in Core YAML instead:
#   security:
#     frame_ancestor_origins:
#       - https://homeassistant.example
#
# This middleware may continue to own TLS-related HSTS and proxy transport.

http:
  middlewares:
    securityHeadersZigbeeLens:
      headers:
        frameDeny: false
        # Leave framing and CSP to Core (exact allowlists).
        customresponseheaders:
          Server: '{{env "DOMAIN"}}'
          X-Powered-By: '{{env "DOMAIN"}}'
        contenttypenosniff: true
        referrerpolicy: no-referrer
        sslredirect: true
        stsSeconds: 63072000
        stsIncludeSubdomains: true
        stsPreload: true
        forceSTSHeader: true
